rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Post media: public read, admin-only write
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['jasoncsalas@gmail.com', 'smiles2785@gmail.com'];
    }
  }
}
