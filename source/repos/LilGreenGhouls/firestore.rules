rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email whitelist — the server-side source of truth
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified
        && request.auth.token.email in ['jasoncsalas@gmail.com', 'smiles2785@gmail.com'];
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        // Only admins can set role to 'admin'; anyone can set their own role to 'viewer'
        && (request.resource.data.role == 'viewer' || isAdmin());
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Subscribers collection
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // FCM push notification tokens
    match /fcmTokens/{tokenId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // Notification requests (admin queues, Cloud Function processes)
    match /notificationRequests/{requestId} {
      allow create: if isAdmin();
      allow read, update: if isAdmin();
    }
  }
}
