rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function canReadReview() {
      // Allow existence checks (resource == null) and normal read paths
      return resource == null
        || resource.data.status == 'published'
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['reviewCount'])
          || request.resource.data.reviewCount == resource.data.reviewCount);
    }

    match /verifications/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.formattedAddress is string
        && request.resource.data.geohash is string
        && request.resource.data.location is latlng;
      allow update: if false;
      allow delete: if false;
    }

    match /landlords/{landlordId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.name is string
        && request.resource.data.type is string;
      allow update: if false;
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if canReadReview();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['pending', 'published']
        && request.resource.data.propertyId is string
        && request.resource.data.overall is number
        && request.resource.data.body is string;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    match /reports/{reportId} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid;
    }

    match /saved/{userId}/items/{itemId} {
      allow read, write: if isOwner(userId);
    }
  }
}
