# Firebase (create project at https://console.firebase.google.com)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Cloud — Maps SDK (Android), Places API (address search)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Set to true when running firebase emulators locally
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false

# EAS (required for push notifications — from `eas init` or expo.dev project settings)
EAS_PROJECT_ID=
